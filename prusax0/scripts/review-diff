#!/bin/sh
# review-diff — produce a diff and changed file list for code review.
#
# Usage:
#   review-diff                     # staged + unstaged changes (default)
#   review-diff working             # same as above
#   review-diff branch <name>       # diff from main...<name>
#   review-diff merge               # most recent merge commit
#   review-diff last <N>            # last N commits
#   review-diff files <f1> [f2..]   # list specific files (no diff, just paths)
#
# Output:
#   Section 1: "## Changed files" — one path per line
#   Section 2: "## Diff" — the unified diff (omitted in "files" mode)
#
# Excludes: vendor/, node_modules/, .bundle/, lock files, generated files,
#           binary files, and minified JS/CSS.

set -e

MAIN_BRANCH="${MAIN_BRANCH:-main}"

# Files to exclude from review (generated, dependencies, lock files, binaries)
exclude_patterns() {
    grep -v -E \
        '(^|/)vendor/|node_modules/|\.bundle/|^Gemfile\.lock$|^yarn\.lock$|^package-lock\.json$|^Cargo\.lock$|\.min\.(js|css)$|^db/structure\.sql$|^db/yugabyte_structure\.sql$|\.rbi$|sorbet/rbi/' \
        || true
}

mode="${1:-working}"
shift 2>/dev/null || true

case "$mode" in
    working)
        diff_output=$(git diff HEAD 2>/dev/null || git diff 2>/dev/null || true)
        files=$(git diff --name-only HEAD 2>/dev/null | exclude_patterns || \
                git diff --name-only 2>/dev/null | exclude_patterns || true)
        ;;
    branch)
        branch_name="${1:?Usage: review-diff branch <name>}"
        diff_output=$(git diff "${MAIN_BRANCH}...${branch_name}" || true)
        files=$(git diff --name-only "${MAIN_BRANCH}...${branch_name}" | exclude_patterns)
        ;;
    merge)
        merge_sha=$(git log --merges -1 --format="%H")
        if [ -z "$merge_sha" ]; then
            echo "Error: no merge commits found" >&2
            exit 1
        fi
        diff_output=$(git diff "${merge_sha}^1..${merge_sha}" || true)
        files=$(git diff --name-only "${merge_sha}^1..${merge_sha}" | exclude_patterns)
        echo "## Merge commit"
        echo ""
        git log -1 --format="  %H %s" "$merge_sha"
        echo ""
        ;;
    last)
        count="${1:?Usage: review-diff last <N>}"
        diff_output=$(git diff "HEAD~${count}..HEAD" || true)
        files=$(git diff --name-only "HEAD~${count}..HEAD" | exclude_patterns)
        echo "## Commits"
        echo ""
        git log --oneline -"${count}"
        echo ""
        ;;
    files)
        if [ $# -eq 0 ]; then
            echo "Usage: review-diff files <file1> [file2...]" >&2
            exit 1
        fi
        echo "## Changed files"
        echo ""
        for f in "$@"; do
            echo "$f"
        done
        exit 0
        ;;
    *)
        echo "Unknown mode: $mode" >&2
        echo "Usage: review-diff [working|branch <name>|merge|last <N>|files <f1>...]" >&2
        exit 1
        ;;
esac

echo "## Changed files"
echo ""
if [ -z "$files" ]; then
    echo "(no files changed)"
else
    echo "$files"
fi
echo ""
echo "## Diff"
echo ""
if [ -z "$diff_output" ]; then
    echo "(no diff)"
else
    echo "$diff_output"
fi