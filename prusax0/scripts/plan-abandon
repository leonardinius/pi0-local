#!/bin/sh
# plan-abandon — Move a plan from doing/ to abandoned/ with a fresh timestamp.
#
# Usage: plan-abandon <name>
#   <name> can be a slug (add-payment-retry), slug.md, or full filename
#   (20260221090632-add-payment-retry.md).
#
# Finds the matching file in plans/doing/, moves it to plans/abandoned/ with a
# fresh Zettelkasten timestamp reflecting abandonment time, then silently calls
# plan-archive to sync the archive index.
# Prints the new path to stdout.

set -eu

usage() {
    echo "Usage: plan-abandon <name>" >&2
    echo "  <name> can be a slug, slug.md, or full timestamped filename" >&2
    exit 1
}

if [ $# -ne 1 ]; then
    usage
fi

input="$1"

PLANS_DIR="/Users/leo/.pi/agent/prusax0/plans"
doing_dir="$PLANS_DIR/doing"
abandoned_dir="$PLANS_DIR/abandoned"

# Strip .md suffix if present for matching purposes.
bare="${input%.md}"

# Try to find the file in doing/.
match=""

# 1. Exact filename match.
if [ -e "$doing_dir/$input" ]; then
    match="$doing_dir/$input"
# 2. Exact filename with .md appended.
elif [ -e "$doing_dir/${input}.md" ]; then
    match="$doing_dir/${input}.md"
else
    # 3. Slug match: find any file ending in -<slug>.md.
    for f in "$doing_dir"/*-"${bare}.md"; do
        if [ -e "$f" ]; then
            match="$f"
            break
        fi
    done
    # 4. Legacy unprefixed file: <slug>.md.
    if [ -z "$match" ] && [ -e "$doing_dir/${bare}.md" ]; then
        match="$doing_dir/${bare}.md"
    fi
fi

if [ -z "$match" ]; then
    echo "Error: no plan matching '$input' found in $doing_dir" >&2
    exit 1
fi

# Extract the slug from the matched filename.
basename_f="$(basename "$match")"
stem="${basename_f%.md}"
# Strip timestamp prefix if present (YYYYMMDDHHmmss-).
if echo "$stem" | grep -qE '^[0-9]{14}-'; then
    slug="${stem#[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-}"
else
    slug="$stem"
fi

# Generate fresh timestamp and move.
timestamp="$(date +%Y%m%d%H%M%S)"
new_filename="${timestamp}-${slug}.md"
new_path="$abandoned_dir/$new_filename"

mkdir -p "$abandoned_dir"
mv "$match" "$new_path"

# Silently sync the archive index.
"$(dirname "$0")/plan-archive" >/dev/null 2>&1 || true

echo "$new_path"
